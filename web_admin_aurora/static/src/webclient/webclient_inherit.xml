<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.WebClient" t-inherit-mode="extension">
        <xpath expr="//NavBar" position="before">
            <SideBar/>
        </xpath>
    </t>

    <!-- Inherit NavBar to hide apps menu and sections menu, leave only systray -->
    <t t-inherit="web.NavBar" t-inherit-mode="extension">
        <xpath expr="//t[@t-call='web.NavBar.AppsMenu']" position="replace"/>
        <xpath expr="//DropdownItem[@t-if='currentApp']" position="replace"/>
        <xpath expr="//t[@t-if='currentAppSections.length']" position="replace"/>
        <xpath expr="//nav" position="attributes">
            <attribute name="class">o_main_navbar o_aurora_topbar justify-content-start align-items-center</attribute>
        </xpath>
        <xpath expr="//nav/*[1]" position="before">
            <div class="o_aurora_mobile_toggle d-md-none ps-3">
                <button class="btn btn-light border-0" t-on-click="() => this.env.bus.trigger('AURORA:TOGGLE-SIDEBAR')">
                    <i class="fa fa-bars" style="font-size: 20px;"/>
                </button>
            </div>
        </xpath>


    </t>
</templates>

