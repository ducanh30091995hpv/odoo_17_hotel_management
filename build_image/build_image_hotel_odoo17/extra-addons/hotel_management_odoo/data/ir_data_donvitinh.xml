<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- UOM Categories -->
    <record id="product_uom_categ_hotel_1" model="uom.category">
        <field name="name">Giờ</field>
    </record>

    <record id="product_uom_categ_hotel_2" model="uom.category">
        <field name="name">Đêm</field>
    </record>

    <record id="product_uom_categ_hotel_3" model="uom.category">
        <field name="name">Ngày</field>
    </record>

    <record id="product_uom_categ_hotel_4" model="uom.category">
        <field name="name">Chai</field>
    </record>

    <record id="product_uom_categ_hotel_5" model="uom.category">
        <field name="name">Ng</field>
    </record>

    <!-- UOM.UOM -->
    <!-- Units -->
    <record id="product_uom_hotel_1" model="uom.uom">
        <field name="category_id" ref="product_uom_categ_hotel_1"/>
        <field name="name">Giờ</field>
        <field name="factor" eval="1.0"/>
        <field name="uom_type">reference</field>
    </record>

    <record id="product_uom_hotel_2" model="uom.uom">
        <field name="category_id" ref="product_uom_categ_hotel_2"/>
        <field name="name">Đêm</field>
        <field name="factor" eval="1.0"/>
        <field name="uom_type">reference</field>
    </record>

    <record id="product_uom_hotel_3" model="uom.uom">
        <field name="category_id" ref="product_uom_categ_hotel_3"/>
        <field name="name">Ngày</field>
        <field name="factor" eval="1.0"/>
        <field name="uom_type">reference</field>
    </record>

    <record id="product_uom_hotel_4" model="uom.uom">
        <field name="category_id" ref="product_uom_categ_hotel_4"/>
        <field name="name">Chai</field>
        <field name="factor" eval="1.0"/>
        <field name="uom_type">reference</field>
    </record>

    <record id="product_uom_hotel_5" model="uom.uom">
        <field name="category_id" ref="product_uom_categ_hotel_5"/>
        <field name="name">Ng</field>
        <field name="factor" eval="1.0"/>
        <field name="uom_type">reference</field>
    </record>
</odoo>
