<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--    Hotel Services Tree View-->
    <record id="hotel_phutroi_view_tree" model="ir.ui.view">
        <field name="name">hotel.phutroi.view.tree</field>
        <field name="model">hotel.phutroi</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="unit_price"/>
                <field name="taxes_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>
    <!--    Services Menu Action-->
    <record id="hotel_phutroi_action" model="ir.actions.act_window">
        <field name="name">Phụ Trội</field>
        <field name="res_model">hotel.phutroi</field>
        <field name="view_mode">tree</field>
    </record>
    <!--    Services Menu-->
    <menuitem id="hotel_phutroi_menu"
              name="Phụ Trội"
              action="hotel_phutroi_action"
              parent="hotel_config_menu"
              sequence="40"/>
</odoo>
