<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Trình xem danh sách thiết bị -->
    <record id="hotel_room_equipment_view_tree" model="ir.ui.view">
        <field name="name">hotel.room.equipment.view.tree</field>
        <field name="model">hotel.room.equipment</field>
        <field name="arch" type="xml">
            <tree decoration-danger="status == 'broken'" decoration-warning="status == 'repairing'" decoration-success="status == 'working'">
                <field name="name"/>
                <field name="room_id"/>
                <field name="category"/>
                <field name="serial_no"/>
                <field name="status" widget="badge" decoration-danger="status == 'broken'" decoration-warning="status == 'repairing'" decoration-success="status == 'working'"/>
                <field name="last_check_date"/>
                <button name="action_report_broken" string="Báo hỏng" type="object" icon="fa-wrench" invisible="status != 'working'"/>
            </tree>
        </field>
    </record>

    <!-- Trình xem form thiết bị -->
    <record id="hotel_room_equipment_view_form" model="ir.ui.view">
        <field name="name">hotel.room.equipment.view.form</field>
        <field name="model">hotel.room.equipment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_report_broken" string="Báo hỏng &amp; Sửa chữa" type="object" class="oe_highlight" invisible="status != 'working'"/>
                    <field name="status" widget="statusbar" statusbar_visible="working,broken,repairing"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên thiết bị (VD: TV LG 43 inch)"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="room_id"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="serial_no"/>
                            <field name="last_check_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ghi chú &amp; Tình trạng" name="notes">
                            <field name="note" placeholder="Mô tả chi tiết tình trạng hoặc lịch sử bảo trì..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action cho thiết bị -->
    <record id="hotel_room_equipment_action" model="ir.actions.act_window">
        <field name="name">Vật tư &amp; Thiết bị phòng</field>
        <field name="res_model">hotel.room.equipment</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có thiết bị nào được đăng ký.
            </p>
            <p>
                Hãy thêm các thiết bị như TV, Điều hòa, Tủ lạnh... để theo dõi tình trạng bảo trì.
            </p>
        </field>
    </record>
</odoo>
