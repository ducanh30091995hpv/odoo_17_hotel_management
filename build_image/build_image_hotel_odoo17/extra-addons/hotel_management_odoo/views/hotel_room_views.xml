<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="hotel_tinhtrangphong_view_kaban" model="ir.ui.view">
        <field name="name">hotel.tinhtrangphong.view.kanban</field>
        <field name="model">hotel.room</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <kanban class="o_hr_employee_kanban view_kanban_custom" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="room_type"/>
                <field name="floor_id"/>
                <field name="loaiphong_id"/>
                <field name="list_price"/>
                <field name="status"/>
                <field name="description"/>
                <templates>
                    <t t-name="card">
                        <div class="cards">
                            <div class="card">
                                <img t-att-src="kanban_image('hotel.room', 'room_image', record.id.raw_value)" 
                                     class="card__image" alt="Room Image"/>
                                <div class="card__overlay">
                                    <div class="card__header">
                                        <img t-if="record.status.raw_value == 'available'" class="card__thumb"
                                             src="/hotel_management_odoo/static/src/image/checked.png" alt=""/>
                                        <img t-if="record.status.raw_value == 'reserved'" class="card__thumb"
                                             src="/hotel_management_odoo/static/src/image/booking.png" alt=""/>
                                        <img t-if="record.status.raw_value == 'occupied'" class="card__thumb"
                                             src="/hotel_management_odoo/static/src/image/customer.png" alt=""/>
                                        <img t-if="record.status.raw_value == 'clean'" class="card__thumb"
                                             src="/hotel_management_odoo/static/src/image/clean-up.png" alt=""/>
                                        <div class="card__header-text">
                                            <h3 class="card__title">
                                                <field name="name"/>
                                            </h3>
                                            <span class="card__status">
                                                <field name="status"/>
                                            </span>
                                        </div>
                                    </div>
                                    <p class="card__description">
                                        Phòng
                                        <field name="room_type"/>
                                        <field name="floor_id"/>
                                        Loại
                                        <field name="loaiphong_id"/>
                                        Đơn giá
                                        <field name="list_price"/>
                                        <field name="description"/>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!--    Hotel Room tree view-->
    <record id="hotel_room_view_tree" model="ir.ui.view">
        <field name="name">hotel.room.view.tree</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="room_type"/>
                <field name="floor_id"/>
                <field name="loaiphong_id"/>
                <field name="list_price"/>
                <field name="list_price_dem"/>
                <field name="list_price_gio"/>
                <field name="status"/>
            </tree>
        </field>
    </record>
    <!--    Hotel Room form view-->
    <record id="hotel_room_view_form" model="ir.ui.view">
        <field name="name">hotel.room.view.form</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <form string="Hotel Room">
                <header>
                    <button name="action_cleanroom_id"
                            invisible="status != 'dirty'"
                            string="Dọn phòng" type="object" class="btn-primary"/>
                    <field name="status" widget="statusbar" readonly="1"/>
                </header>
                <sheet>
                    <field name="room_image" widget="image"
                           class="oe_avatar"
                           options="{'preview_image': 'room_image'}"/>
                    <div class="oe_title">
                        <label for="name" string="Name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <notebook>
                        <page name="information_hotel_room"
                              string="Information">
                            <group>
                                <group>
                                    <field name="floor_id" string="Floor"/>
                                    <field name="loaiphong_id" string="Loại phòng"/>
                                    <field name="user_id" select="2"
                                           string="Room Manager"/>
                                    <field name="taxes_ids"
                                           widget="many2many_tags"
                                           string="Customer Taxes"/>
                                </group>
                                <group>
                                    <field name="room_type"/>
                                    <field name="list_price" widget="monetary"
                                           string="Giá theo ngày"/>
                                    <field name="list_price_dem" widget="monetary" string="Giá qua đêm"/>
                                    <field name="list_price_gio" widget="monetary" string="Giá giờ"/>
                                    <field name="num_person"/>
                                    <field name="uom_id" invisible="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Amenities">
                            <group>
                                <field name="room_amenities_ids"
                                       widget="many2many_tags"
                                       string="Room Amenities"/>
                            </group>
                        </page>
                        <page string="Mô tả">
                            <field name="description"/>
                        </page>
                        <page name="special_prices" string="Giá đặc biệt (Lễ/Cuối tuần)">
                            <field name="special_price_ids">
                                <tree editable="bottom">
                                    <field name="type"/>
                                    <field name="day_of_week" invisible="type != 'weekend'" required="type == 'weekend'"/>
                                    <field name="holiday_id" invisible="type != 'holiday'" required="type == 'holiday'"/>
                                    <field name="calculation_method"/>
                                    <field name="fixed_amount_to_add" invisible="calculation_method != 'add_amount'" required="calculation_method == 'add_amount'"/>
                                    <field name="percent_to_add" invisible="calculation_method != 'add_percent'" required="calculation_method == 'add_percent'"/>
                                    <field name="price_unit" invisible="calculation_method != 'fixed'" required="calculation_method == 'fixed'"/>
                                    <field name="price_unit_dem" invisible="calculation_method != 'fixed'" required="calculation_method == 'fixed'"/>
                                    <field name="price_unit_gio" invisible="calculation_method != 'fixed'" required="calculation_method == 'fixed'"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Vật tư &amp; Thiết bị" name="equipment">
                            <field name="equipment_ids">
                                <tree editable="bottom" decoration-danger="status == 'broken'" decoration-warning="status == 'repairing'" decoration-success="status == 'working'">
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="serial_no"/>
                                    <field name="status" widget="badge" decoration-danger="status == 'broken'" decoration-warning="status == 'repairing'" decoration-success="status == 'working'"/>
                                    <field name="last_check_date"/>
                                    <button name="action_report_broken" string="Báo hỏng" type="object" icon="fa-wrench" invisible="status != 'working'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                    <field name="activity_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!--    Hotel Room menu action-->
    <record id="hotel_room_action" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hotel.room</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="context">{}</field>
    </record>

    <record id="hotel_cleanup_room" model="ir.actions.server">
        <field name="name">Clean up</field>
        <field name="model_id" ref="model_hotel_room"/>
        <field name="binding_model_id" ref="hotel_management_odoo.model_hotel_room"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.change_cleanup_room()
        </field>
    </record>

    <record id="hotel_cleaned_room" model="ir.actions.server">
        <field name="name">Cleaned</field>
        <field name="model_id" ref="model_hotel_room"/>
        <field name="binding_model_id" ref="hotel_management_odoo.model_hotel_room"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.change_cleaned_room()
        </field>
    </record>

    <record id="hotel_repair_room" model="ir.actions.server">
        <field name="name">Repair</field>
        <field name="model_id" ref="model_hotel_room"/>
        <field name="binding_model_id" ref="hotel_management_odoo.model_hotel_room"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.change_repair_room()
        </field>
    </record>

    <record id="hotel_repaired_room" model="ir.actions.server">
        <field name="name">Repaired</field>
        <field name="model_id" ref="model_hotel_room"/>
        <field name="binding_model_id" ref="hotel_management_odoo.model_hotel_room"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.change_repaired_room()
        </field>
    </record>

    <!--Room Menu-->
    <menuitem id="hotel_room_menu"
              name="Room"
              action="hotel_room_action"
              parent="hotel_config_menu"
              sequence="20"/>

    <menuitem id="hotel_room_equipment_menu"
              name="Vật tư &amp; Thiết bị"
              action="hotel_room_equipment_action"
              parent="hotel_config_menu"
              sequence="25"/>
</odoo>
