<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--    Products menu action-->
    <record id="lunch_product_action" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">lunch.product</field>
        <field name="view_mode">tree,kanban,form</field>
    </record>

    <record id="lunch_product_view_form_inherit" model="ir.ui.view">
        <field name="name">lunch.product.view.form.inherit</field>
        <field name="model">lunch.product</field>
        <field name="inherit_id" ref="lunch.lunch_product_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price']" position="after">
                <field name="product_id" groups="stock.group_stock_user"/>
            </xpath>
        </field>
    </record>
    <!--    Vendors menu action-->
    <record id="lunch_supplier_action" model="ir.actions.act_window">
        <field name="name">Vendors</field>
        <field name="res_model">lunch.supplier</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
    <!--    Products Menu-->
    <menuitem id="lunch_product_menu"
              name="Products"
              action="lunch_product_action"
              parent="food_menu"
              sequence="10"/>
    <!--    Vendors Menu-->
    <menuitem id="lunch_supplier_menu"
              name="Vendors"
              action="lunch_supplier_action"
              parent="food_menu"
              sequence="20"/>
</odoo>
