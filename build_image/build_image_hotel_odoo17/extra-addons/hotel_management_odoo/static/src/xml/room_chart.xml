<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="hotel_management_odoo.RoomChart">
        <div class="o_room_chart_container">
            <div class="o_room_chart_header p-3 bg-white border-bottom">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <h4 class="m-0"><i class="fa fa-desktop mr-2"/> Sơ đồ phòng</h4>
                    </div>
                    <div class="col">
                        <div class="d-flex align-items-center">
                            <label class="mr-2 mb-0">Loại phòng:</label>
                            <select class="form-control form-control-sm w-auto" t-on-change="onRoomTypeChange">
                                <option value="all">Tất cả</option>
                                <t t-foreach="state.room_types" t-as="rt" t-key="rt[0]">
                                    <option t-att-value="rt[0]"><t t-esc="rt[1]"/></option>
                                </t>
                            </select>
                            
                            <label class="mr-2 mb-0 ml-3" style="margin-left: 15px;">Ngày xem:</label>
                            <input type="date" class="form-control form-control-sm w-auto" t-att-value="state.targetDate" t-on-change="onDateChange"/>
                            
                            <button class="btn btn-sm btn-light ml-2" t-on-click="refreshData" title="Làm mới dữ liệu" style="margin-left: 10px;">
                                <i class="fa fa-refresh"/> Làm mới
                            </button>
                        </div>
                    </div>
                </div>
                <div class="o_room_chart_filters mt-3 d-flex flex-wrap gap-2 text-sm">
                    <button class="btn btn-sm btn-outline-secondary" t-on-click="() => this.onFilterStatus('all')">Tất cả</button>
                    <button class="btn btn-sm btn-outline-info" t-on-click="() => this.onFilterStatus('arriving')">
                        <i class="fa fa-male mr-1"/> Chuẩn bị đến (<t t-esc="state.counts.arriving"/>)
                    </button>
                    <button class="btn btn-sm btn-outline-primary" t-on-click="() => this.onFilterStatus('in_house')">
                        <i class="fa fa-walking mr-1"/> Đang ở (<t t-esc="state.counts.in_house"/>)
                    </button>
                    <button class="btn btn-sm btn-outline-danger" t-on-click="() => this.onFilterStatus('departing')">
                        <i class="fa fa-walking fa-flip-horizontal mr-1"/> Chuẩn bị rời đi (<t t-esc="state.counts.departing"/>)
                    </button>
                    <button class="btn btn-sm btn-outline-success" t-on-click="() => this.onFilterStatus('available')">
                        <i class="fa fa-bullseye mr-1"/> Phòng trống (<t t-esc="state.counts.available + state.counts.clean"/>)
                    </button>
                    <button class="btn btn-sm btn-warning text-white" t-on-click="() => this.onFilterStatus('dirty')">
                        <i class="fa fa-wrench mr-1"/> Phòng bẩn (<t t-esc="state.counts.dirty"/>)
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" t-on-click="() => this.onFilterStatus('repair')">
                        <i class="fa fa-times mr-1"/> Phòng đang sửa (<t t-esc="state.counts.repair"/>)
                    </button>
                </div>
                <div class="mt-2 text-danger small">
                    (* Di chuyển chọn hình ảnh để xem thông tin chi tiết đặt phòng)
                </div>
            </div>

            <div class="o_dashboard_buttons p-3 bg-light border-bottom row m-0" t-if="state.isAdmin">
                
                <!-- Cột Thống kê -->
                <div class="col-md-4 col-12 mb-3 mb-md-0">
                    <h6 class="font-weight-bold mb-3"><i class="fa fa-pie-chart mr-1"/> Thống kê tổng quan</h6>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-outline-secondary flex-grow-1 text-left" t-on-click="(e) => this.total_rooms(e)">
                            <i class="fa fa-bed"/> Tổng phòng: <t t-esc="state.dash.total_room || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-primary flex-grow-1 text-left" t-on-click="(e)=> this.available_rooms(e)">
                            <i class="fa fa-check-circle"/> Phòng trống: <t t-esc="state.dash.available_room || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-info flex-grow-1 text-left" t-on-click="(e) => this.fetch_total_staff(e)">
                            <i class="fa fa-group"/> Cán bộ: <t t-esc="state.dash.staff || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-secondary flex-grow-1 text-left" t-on-click="(e)=> this.fetch_total_vehicle(e)">
                            <i class="fa fa-car"/> Tổng xe: <t t-esc="state.dash.total_vehicle || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-success flex-grow-1 text-left" t-on-click="(e)=> this.fetch_available_vehicle(e)">
                            <i class="fa fa-car"/> Xe trống: <t t-esc="state.dash.available_vehicle || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-primary flex-grow-1 text-left" t-on-click="(e)=> this.view_total_events(e)">
                            <i class="fa fa-ticket"/> Tổng sự kiện: <t t-esc="state.dash.total_event || 0"/>
                        </button>
                    </div>
                </div>
                
                <!-- Cột Nghiệp vụ -->
                <div class="col-md-4 col-12 mb-3 mb-md-0 border-left">
                    <h6 class="font-weight-bold mb-3"><i class="fa fa-list-ul mr-1"/> Xử lý nghiệp vụ</h6>
                    <div class="d-flex flex-wrap gap-2">
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-success flex-grow-1 text-left" t-on-click="(e) => this.check_ins(e)">
                            <i class="fa fa-sign-in"/> Check In: <t t-esc="state.dash.check_in || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-dark flex-grow-1 text-left" t-on-click="(e)=> this.reservations(e)">
                            <i class="fa fa-bookmark"/> Trạng thái đặt: <t t-esc="state.dash.reservation || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-warning text-dark flex-grow-1 text-left" t-on-click="(e)=>this.check_outs(e)">
                            <i class="fa fa-sign-out"/> Check Out hôm nay: <t t-esc="state.dash.check_out || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-danger flex-grow-1 text-left" t-on-click="(e) => this.fetch_today_events(e)">
                            <i class="fa fa-calendar"/> Sự kiện hôm nay: <t t-esc="state.dash.today_events || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-warning text-dark flex-grow-1 text-left" t-on-click="(e) => this.fetch_pending_events(e)">
                            <i class="fa fa-exclamation-triangle"/> Sự kiện chờ: <t t-esc="state.dash.pending_events || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-danger flex-grow-1 text-left" t-on-click="(e)=> this.fetch_food_item(e)">
                            <i class="fa fa-cutlery"/> Món ăn: <t t-esc="state.dash.food_items || 0"/>
                        </button>
                        <button groups="hotel_management_odoo.hotel_group_reception" class="btn btn-outline-warning text-dark flex-grow-1 text-left" t-on-click="(e)=>this.fetch_food_order(e)">
                            <i class="fa fa-cutlery"/> Đơn món: <t t-esc="state.dash.food_order || 0"/>
                        </button>
                    </div>
                </div>

                <!-- Cột Tài chính -->
                <div class="col-md-4 col-12 border-left" groups="hotel_management_odoo.hotel_group_admin">
                    <h6 class="font-weight-bold mb-3"><i class="fa fa-line-chart mr-1"/> Chỉ số tài chính</h6>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-dark w-100 text-left">
                            <i class="fa fa-usd"/> Tổng DT: <t t-esc="state.dash.total_revenue || 0"/>
                        </button>
                        <button class="btn btn-success w-100 text-left">
                            <i class="fa fa-money"/> DT hôm nay: <t t-esc="state.dash.today_revenue || 0"/>
                        </button>
                        <button class="btn btn-danger w-100 text-left">
                            <i class="fa fa-credit-card"/> Chờ thanh toán: <t t-esc="state.dash.pending_payment || 0"/>
                        </button>
                        <button class="btn btn-info flex-grow-1 text-left">
                            <i class="fa fa-percent"/> Tỷ lệ lấp đầy: <t t-esc="state.dash.occupancy_rate || 0"/>
                        </button>
                        <button class="btn btn-primary flex-grow-1 text-left">
                            <i class="fa fa-line-chart"/> ADR: <t t-esc="state.dash.adr || 0"/>
                        </button>
                        <button class="btn btn-secondary flex-grow-1 text-left">
                            <i class="fa fa-bar-chart"/> RevPAR: <t t-esc="state.dash.revpar || 0"/>
                        </button>
                    </div>
                </div>
            </div>

            <div class="o_room_main_layout">
                <!-- Room Grid area -->
                <div class="o_room_chart_content h-100 p-3">
                    <t t-foreach="groupedRooms" t-as="group" t-key="group.floor.id">
                        <div class="mb-4">
                            <h5 class="border-bottom pb-2 mb-3"><t t-esc="group.floor.name"/></h5>
                            <div class="o_room_grid">
                                <t t-foreach="group.rooms" t-as="room" t-key="room.id">
                                    <div t-attf-class="o_room_card bg-{{room.visual_color}}" t-on-click="() => this.openRoom(room)">
                                        <div class="o_room_number"><t t-esc="room.name"/></div>
                                        <div class="o_room_type"><t t-esc="room.loaiphong"/></div>
                                        <div class="o_room_status_icon">
                                            <i t-attf-class="fa {{room.visual_icon}} fa-lg"/>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </t>
                </div>
                
                <!-- Sidebar Charts -->
                <div class="o_room_sidebar_charts h-100" t-if="state.isAdmin">
                    <h6 class="text-center font-weight-bold mb-3 border-bottom pb-2">Biểu đồ phân tích</h6>
                    <div class="card p-3 mb-3 shadow-sm">
                        <h6 class="card-title text-center text-sm">7-Day Revenue Trend</h6>
                        <div style="height: 200px; position: relative;">
                            <canvas id="revenue_trend_chart"></canvas>
                        </div>
                    </div>
                    <div class="card p-3 mb-3 shadow-sm">
                        <h6 class="card-title text-center text-sm">7-Day Occupancy Trend</h6>
                        <div style="height: 200px; position: relative;">
                            <canvas id="occupancy_trend_chart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
