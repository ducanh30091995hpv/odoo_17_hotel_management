<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_fb_report_view_form" model="ir.ui.view">
        <field name="name">hotel.fb.report.view.form</field>
        <field name="model">hotel.fb.report</field>
        <field name="arch" type="xml">
            <form string="Bao cao phan tich F&amp;B">
                <group>
                    <group>
                        <field name="date_from"/>
                    </group>
                    <group>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_export_xlsx" string="Xuat Excel" type="object" class="btn-primary"/>
                    <button string="Huy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hotel_fb_report_action" model="ir.actions.act_window">
        <field name="name">Báo cáo phân tích F&amp;B</field>
        <field name="res_model">hotel.fb.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="hotel_fb_report_menu"
              name="Báo cáo phân tích F&amp;B"
              action="hotel_fb_report_action"
              parent="hotel_reporting_menu"
              sequence="25"/>
</odoo>
