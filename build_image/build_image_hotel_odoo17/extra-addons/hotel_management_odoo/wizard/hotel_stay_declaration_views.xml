<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hotel_stay_declaration_view_form" model="ir.ui.view">
        <field name="name">hotel.stay.declaration.view.form</field>
        <field name="model">hotel.stay.declaration</field>
        <field name="arch" type="xml">
            <form string="Khai báo tạm trú">
                <group>
                    <group>
                        <field name="date_from"/>
                    </group>
                    <group>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_export_xlsx" string="Xuất Excel" type="object" class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hotel_stay_declaration_action" model="ir.actions.act_window">
        <field name="name">Khai báo tạm trú</field>
        <field name="res_model">hotel.stay.declaration</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="hotel_stay_declaration_menu"
              name="Khai báo tạm trú"
              action="hotel_stay_declaration_action"
              parent="hotel_reporting_menu"
              sequence="10"/>
</odoo>
