<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_early_checkout_wizard_form" model="ir.ui.view">
        <field name="name">early.checkout.wizard.form</field>
        <field name="model">early.checkout.wizard</field>
        <field name="arch" type="xml">
            <form string="Trả phòng sớm">
                <sheet>
                    <group>
                        <field name="booking_id" invisible="1"/>
                        <field name="policy" widget="radio"/>
                        <field name="penalty_amount" invisible="policy != 'penalty'" required="policy == 'penalty'"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Xác nhận Trả Phòng" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Hủy bỏ" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
