<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_generate_stayover_cleaning" model="ir.cron">
            <field name="name">Hotel: Generate Stay-over Cleaning Requests</field>
            <field name="model_id" ref="model_cleaning_request"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_stayover_cleaning()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).replace(hour=8, minute=0, second=0)"/>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
