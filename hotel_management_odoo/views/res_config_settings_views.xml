<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.hotel</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="5"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Hotel Management" string="Hotel" name="hotel_management_odoo">
                    <block title="Cấu hình nhận trả phòng" id="hotel_section">
                        <setting string="Một ngày đủ 24 tiếng" help="Tính ngày đủ 24 tiếng thay vì tính theo giờ AM PM">
                            <field name="mot_ngay_du_24h" class="o_light_label"/>
                            <div class="text-muted content-group mt16">
                                <span>1 ngày được tính là bao nhiêu giờ:</span>
                                <field name="so_gio_1_ngay" class="text-center" style="width: 15%"/>
                            </div>
                        </setting>
                        <setting string="Checkin và Checkout"
                                 help="Khách Checkin và Checkout trong cùng 1 ngày được tính">
                            <field name="checkin_checkout_cung_ngay" class="o_light_label"/>
                        </setting>
                        <setting string="Giờ nhận phòng" help="Giờ nhận phòng của khách sạn">
                            <div class="content-group">
                                <field name="gio_nhan_phong" class="o_light_label"/>
                            </div>
                        </setting>
                        <setting string="Giờ trả phòng" help="Giờ trả phòng của khách sạn">
                            <div class="content-group">
                                <field name="gio_tra_phong" class="o_light_label"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Quy định giờ nghỉ" id="hotel_section_1">
                        <setting string="Nhận phòng từ" help="Khung giờ nghỉ qua đêm áp dụng cho khách sạn">
                            <field name="nhan_phong_tu" class="o_light_label"/>
                        </setting>
                        <setting string="Nhận phòng đến trước" help="Khung giờ nghỉ qua đêm áp dụng cho khách sạn">
                            <field name="nhan_phong_den_truoc" class="o_light_label"/>
                        </setting>
                        <setting string="Và trả phòng trước xH hôm sau"
                                 help="Khung giờ nghỉ qua đêm áp dụng cho khách sạn">
                            <field name="va_tra_phong_truoc" class="o_light_label"/>
                        </setting>
                    </block>
                    <block title="Tự động chọn qua đêm hoặc theo ngày" id="hotel_section_2">
                        <setting string="Tự động chọn Qua đêm nếu" help="Khách Nhận Phòng sau thời điểm">
                            <field name="tu_dong_chon_qua_dem_khi_nhan_phong" class="o_light_label"/>
                            <div class="text-muted content-group mt16">
                                <span>Thời điểm</span>
                                <field name="tu_dong_gio" class="text-center"
                                       style="width: 15%"/>
                                &amp;nbsp;&amp;nbsp;:
                                <field name="tu_dong_phut" class="text-center"
                                       style="width: 15%"/>
                            </div>
                        </setting>
                        <setting string="Tự động chọn Qua đêm nếu" help="Khách Trả Phòng sau thời điểm">
                            <field name="tu_dong_chon_qua_dem_khi_tra_phong" class="o_light_label"/>
                            <div class="text-muted content-group mt16">
                                <span>Thời điểm</span>
                                <field name="tu_dong_tra_gio" class="text-center"
                                       style="width: 15%"/>
                                &amp;nbsp;&amp;nbsp;:
                                <field name="tu_dong_tra_phut" class="text-center"
                                       style="width: 15%"/>
                            </div>
                        </setting>
                        <setting
                                string="Tự động chọn Qua đêm nếu khách Checkin trong khung giờ qua đêm và ở quá từ số tiếng">
                            <field name="tu_dong_qua_dem_khach_checkin_qua_dem_va_o_qua_so_tieng"
                                   class="o_light_label"/>
                        </setting>
                        <setting string="Tự động chọn Qua đêm nếu số tiền ở giờ lớn hơn số tiền ở Qua đêm">
                            <field name="tu_dong_qua_dem_neu_so_tien_gio_lon_hon_so_tien_qua_dem"
                                   class="o_light_label"/>
                        </setting>
                        <setting
                                string="Tự động chọn Theo Ngày nếu số tiền Qua Đêm hoặc Theo Giờ lớn hơn số tiền Theo Ngày">
                            <field name="tudong_ngay_neu_tien_quadem_hoac_gio_lon_hon_tien_ngay"
                                   class="o_light_label"/>
                        </setting>
                    </block>
                    <block title="Cấu hình quy định tiền phòng" id="hotel_section_3">
                        <setting string="Làm tròn thời gian nếu khách nghỉ">
                            <div class="text-muted content-group mt16">
                                <span>Quá</span>
                                <field name="lam_tron_time_neu_qua" class="text-center"
                                       style="width: 15%"/>
                            </div>
                        </setting>
                        <setting string="Chỉ bắt đầu tính phụ trội nếu quá giờ Checkin hoặc Checkout">
                            <field name="tinh_phu_troi_neu_qua_gio_checkin_checkout" class="o_light_label"/>
                        </setting>
                        <setting string="Không tính tiền phòng đối với các hóa đơn ở với thời gian không quá.">
                            <field name="khong_tinh_tien_phong_voi_hoa_don_time_khong_qua" class="o_light_label"/>
                            <div class="text-muted content-group mt16">
                                <span>Dưới</span>
                                <field name="so_phut_khong_tinh_tien" class="text-center" style="width: 15%"/>
                                <span>Phút</span>
                            </div>
                        </setting>
                        <setting string="Cho phép tính tiền các tiếng mặc định áp dụng cho các phòng sau 2h đầu">
                            <field name="tinh_tien_cac_tieng_mac_dinh_ap_dung_sau_2h_dau" class="o_light_label"/>
                            <div class="text-muted content-group mt16">
                                <span>Số tiền mặc định</span>
                                <field name="so_tien_ap_dung" class="text-center"
                                       style="width: 15%"/>
                                <span>VNĐ</span>
                            </div>
                            <div class="text-muted content-group mt16">
                                <span>Số tiền trên mỗi tiếng từ tiếng thứ 3</span>
                                <field name="so_tien_ap_dung_tieng_thu_3" class="text-center"
                                       style="width: 15%"/>
                                <span>VNĐ</span>
                            </div>
                        </setting>
                        <setting
                                string="Nếu khách nghỉ ngày quá tiếng lẻ sẽ tính thêm tiếng lẻ không tính thành một ngày">
                            <field name="nghi_ngay_qua_tieng_le_tinh_them_tieng_khong_tinh_thanh_1_ngay"
                                   class="o_light_label"/>
                        </setting>
                    </block>
                    <block title="Cấu hình tài khoản ngân hàng sử dụng QR-Code" id="hotel_section_4">
                        <setting string="Tài khoản ngân hàng">
                            <div class="text-muted content-group mt16">
                                <span>Tên ngân hàng:</span>
                                <field name="tennganhang" class="text-center"
                                       style="width: 100%"/>
                            </div>
                            <div class="text-muted content-group mt16">
                                <span>Số tài khoản ngân hàng</span>
                                <field name="sotaikhoannganhang" class="text-center"
                                       style="width: 100%"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Cấu hình bill thanh toán" id="hotel_section_5">
                        <setting string="Mô tả chân trang">
                            <div class="text-muted content-group mt16">
                                <span>Lời chào chân trang:</span>
                                <field name="loichaochantrang_bill" style="width: 100%"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Cấu hình OTA" id="hotel_section_6">
                        <setting string="Tài khoản Booking.com">
                            <div class="text-muted content-group mt16">
                                <field name="username_booking_com" style="width: 100%"/>
                                <field name="password_booking_com" style="width: 100%" password="True"/>
                            </div>
                        </setting>
                        <setting string="Tài khoản Expedia">
                            <div class="text-muted content-group mt16">
                                <field name="username_expedia" style="width: 100%"/>
                                <field name="password_expedia" style="width: 100%" password="True"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Cấu hình Thông báo Zalo ZNS / SMS" id="hotel_section_7">
                        <setting string="Bật thông báo" help="Tự động gửi tin nhắn khi đặt phòng hoặc trả phòng">
                            <field name="enable_zalo_notification"/>
                        </setting>
                        <setting string="Thông tin Zalo OA" invisible="not enable_zalo_notification">
                            <div class="text-muted content-group mt16">
                                <span>Zalo OA ID</span>
                                <field name="zalo_oa_id" style="width: 100%"/>
                                <span>Access Token</span>
                                <field name="zalo_access_token" style="width: 100%"/>
                            </div>
                        </setting>
                        <setting string="Mẫu tin nhắn (Templates)" invisible="not enable_zalo_notification">
                            <div class="text-muted content-group mt16">
                                <span>Template Đặt phòng (Reserved)</span>
                                <field name="zalo_template_reserved" style="width: 100%"/>
                                <span>Template Trả phòng (Checkout)</span>
                                <field name="zalo_template_checkout" style="width: 100%"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Cấu hình Thanh toán Tự động (PayOS)" id="hotel_section_8">
                        <setting string="Kết nối PayOS" help="Tự động nhận diện thanh toán qua VietQR">
                            <div class="text-muted content-group mt16">
                                <span>Client ID</span>
                                <field name="payos_client_id" style="width: 100%"/>
                                <span>API Key</span>
                                <field name="payos_api_key" style="width: 100%"/>
                                <span>Checksum Key</span>
                                <field name="payos_checksum_key" style="width: 100%"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Cấu hình Dọn phòng Tự động (Stay-over)" id="hotel_section_9">
                        <setting string="Bật dọn phòng tự động" help="Tự động tạo yêu cầu dọn phòng định kỳ cho khách ở lại.">
                            <field name="enable_stayover_cleaning"/>
                        </setting>
                        <setting string="Đội dọn dẹp mặc định" invisible="not enable_stayover_cleaning">
                            <div class="text-muted content-group mt16">
                                <field name="stayover_cleaning_team_id" style="width: 100%"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="hotel_config_settings_action" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'hotel_management_odoo', 'bin_size': False}</field>
    </record>
    <menuitem id="hotel_settings_menu"
              name="General Settings"
              parent="hotel_config_menu"
              sequence="0"
              action="hotel_config_settings_action"
              groups="base.group_system"/>
</odoo>