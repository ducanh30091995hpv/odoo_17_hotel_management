<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hotel_management_odoo.CCCDScannerModal" owl="1">
        <div class="o_cccd_scanner_modal modal show d-block" tabindex="-1" role="dialog">
            <div class="modal-dialog modal-lg" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Quét mã QR CCCD</h5>
                        <button type="button" class="btn-close" t-on-click="props.close" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center">
                        <div id="cccd_video_container" style="position: relative; width: 100%; max-width: 600px; margin: 0 auto; aspect-ratio: 4/3; background: #000; overflow: hidden; border-radius: 8px;">
                            <video id="cccd_video" style="width: 100%; height: 100%; object-fit: cover;" autoplay="true" playsinline="true"></video>
                            <div class="scanner-laser" style="position: absolute; top: 0; left: 0; width: 100%; height: 2px; background: rgba(0,255,0,0.5); box-shadow: 0 0 10px #0f0; animation: scan 2s infinite linear;"></div>
                        </div>
                        <p class="mt-3 text-muted">Vui lòng hướng Camera về phía mã QR trên thẻ CCCD</p>
                        <div t-if="state.error" class="alert alert-danger mt-2">
                            <t t-esc="state.error"/>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" t-on-click="props.close">Đóng</button>
                    </div>
                </div>
            </div>
            <style>
                @keyframes scan {
                    0% { top: 10%; }
                    50% { top: 90%; }
                    100% { top: 10%; }
                }
            </style>
        </div>
    </t>
</templates>
